APP_ENV=production
ADMIN_PASSWORD=change-this-password
BASE_URL=https://photos.example.com
SECRET_KEY=change-this-long-random-secret
DATA_DIR=/data
DATABASE_URL=sqlite:////data/db/app.db
APP_BASE_PATH=/events
APP_TITLE=Wedding Photos
ALBUM_NAME=Свадебный альбом
MAX_UPLOAD_BYTES=26214400
DISK_FREE_RESERVE_BYTES=5368709120
MAX_IMAGE_PIXELS=25000000
ORIGINAL_IMAGE_OPTIMIZE_MIN_BYTES=5242880
ORIGINAL_IMAGE_MAX_EDGE=3200
ORIGINAL_IMAGE_QUALITY=86
WEB_CONCURRENCY=1

# Frontend build settings.
VITE_APP_BASE_PATH=/events/
VITE_ALBUM_TITLE=Свадебный альбом
VITE_MAX_UPLOAD_BYTES=26214400
VITE_SHARE_TITLE=Свадебное фото

# Operational scripts.
